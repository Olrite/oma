{
  "schemaVersion": 1,
  "id": "oma",
  "version": "${version}",
  "name": "o.m.a.",
  "description": "A 2b2t Meteor Client utility addon",
  "authors": [
    "Olrite"
  ],
  "contact": {
    "sources": "https://github.com/Olrite/oma"
  },
  "license": "AGPL-3.0-only",

  "icon": "assets/Main/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "dev.oma.addon.Main"
    ]
  },
  "mixins": [
    "addon.mixins.json",
    "addon-meteor.mixins.json",
    "addon-xaero.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "225,25,25"
  },
  "depends": {
    "java": ">=25",
    "minecraft": "~26.1",
    "meteor-client": "*"
  }
}
